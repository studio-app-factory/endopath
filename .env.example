# Endopath — environment variables
#
# Copy to .env (gitignored) for local builds, or set these as repo secrets
# in GitHub Actions for CI release builds. Vite inlines values prefixed
# with VITE_ at build time.

# RevenueCat public API keys (per platform).
# Get them from https://app.revenuecat.com → Project → API Keys.
# Required for real in-app purchases on Android / iOS. If left blank,
# the paywall falls back to a dev mock that grants premium for free —
# DO NOT ship a release build without these set.
VITE_REVENUECAT_API_KEY_IOS=
VITE_REVENUECAT_API_KEY_ANDROID=

# AdMob banner unit IDs (production builds only).
# When unset, the app uses Google's test banner IDs — safe for dev but never
# ship a release build without these.
#   Android: ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
#   iOS:     ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
# Get them from https://apps.admob.com → App → Ad units.
VITE_ADMOB_BANNER_ID_ANDROID=
VITE_ADMOB_BANNER_ID_IOS=

# AdMob APP IDs (NOT the same as banner IDs above).
# These get injected into AndroidManifest.xml / Info.plist by the CI build.
# In CI these go into GitHub secrets (no VITE_ prefix). Locally you can
# leave them blank — they only matter for release builds.
# ADMOB_APP_ID_ANDROID=
# ADMOB_APP_ID_IOS=
