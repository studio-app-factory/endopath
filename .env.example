# Endopath — environment variables
#
# Copy to .env (gitignored) for local builds, or set these as repo secrets
# in GitHub Actions for CI release builds. Vite inlines values prefixed
# with VITE_ at build time.

# RevenueCat public API keys (per platform).
# Get them from https://app.revenuecat.com → Project → API Keys.
# Required for real in-app purchases on Android / iOS. If left blank,
# the paywall falls back to a dev mock that grants premium for free —
# DO NOT ship a release build without these set.
VITE_REVENUECAT_API_KEY_IOS=
VITE_REVENUECAT_API_KEY_ANDROID=
